# WrapMind Environment Configuration
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit secrets.

# ── Auth Mode (VITE_DEV_AUTH) ─────────────────────────────────────────────────
# Controls how the app handles authentication. Must be set explicitly.
#
# VITE_DEV_AUTH=0  → local Supabase mode (Docker). Requires .env.local override.
#                    Sets VITE_SUPABASE_URL=http://127.0.0.1:54321 and the
#                    matching local anon key from your Docker instance.
#                    Run: supabase start  (in ~/wrapmind/supabase/)
#
# VITE_DEV_AUTH=1  → prototype mode. Uses localStorage seed data.
#                    Supabase auth is bypassed entirely. No backend needed.
#                    Useful for UI development without a Supabase instance.
#
# (unset or any other value) → production Supabase. Uses this file's URLs/keys.

# ── Supabase ─────────────────────────────────────────────────────────────────
# Production values (safe to commit — publishable URL + anon key only).
# Override per-mode values in .env.local (gitignored).

VITE_SUPABASE_URL=https://nbewyeoiizlsfmbqoist.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_jQHCvoVBeWqMuc_P40HOJg_KggDk9dh
