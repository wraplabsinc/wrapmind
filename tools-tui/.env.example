# ShopMonkey Import TUI — Environment Variables
# Copy this file to .env and fill in your values.

# Required
SHOPMONKEY_TOKEN=

# WrapMind organization ID (from Supabase organizations table)
# All sm_import_* rows use this org_id
WRAPMIND_ORG_ID=00000000-0000-0000-0000-000000000001

# Dev Supabase (local Kong proxy → local Docker Supabase)
SUPABASE_URL_DEV=http://wrapos.cloud:54321
SUPABASE_SERVICE_ROLE_KEY_DEV=

# Production Supabase (direct)
SUPABASE_URL_PROD=https://nbewyeoiizlsfmbqoist.supabase.co
SUPABASE_SERVICE_ROLE_KEY_PROD=

# Optional
LOCATION_ID=
SM_API_BASE=https://api.shopmonkey.cloud/v3
