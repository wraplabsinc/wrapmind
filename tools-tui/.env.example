# ShopMonkey Import TUI — Environment Variables
# Copy this file to .env and fill in your values.
# The TUI will also read these from .env on startup.

# Required
SHOPMONKEY_TOKEN=
ORG_ID=

# Dev Supabase (local Kong proxy → local Docker Supabase)
SUPABASE_URL_DEV=http://wrapos.cloud:54321

# Production Supabase (direct)
SUPABASE_URL_PROD=https://nbewyeoiizlsfmbqoist.supabase.co

# Service role key — works for both servers if they share the same key
# Otherwise set per-server keys below (not currently supported — use the same key)
SUPABASE_SERVICE_ROLE_KEY=

# Optional
LOCATION_ID=
SM_API_BASE=https://api.shopmonkey.cloud/v3
